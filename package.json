{
    "name": "@leyyo/http",
    "version": "4.0.5",
    "description": "Http common",
    "keywords": [
        "http state",
        "http error state",
        "http success state",
        "http redirect state",
        "http protocol",
        "http mock",
        "request mock",
        "response mock"
    ],
    "repository": {
        "type": "git",
        "url": "git+https://github.com/leyyonet/http.git"
    },
    "bugs": {
        "url": "https://github.com/leyyonet/http.git/issues",
        "email": "mustafayelmer@gmail.com"
    },
    "homepage": "https://github.com/leyyonet/http.git/#readme",
    "author": {
        "name": "Mustafa Yelmer",
        "email": "mustafayelmer@gmail.com"
    },
    "main": "dist/index.js",
    "types": "dist/index.d.ts",
    "exports": {
        ".": "./dist/index.js"
    },
    "type": "module",
    "scripts": {
        "build": "leyyo clear-dist && tsc && leyyo minify && leyyo assets",
        "build-all": "npm run lint && npm run format-force && npm run test && npm run build",
        "clear-dist": "leyyo clear-dist",
        "clear-nm": "leyyo clear-nm",
        "format-check": "prettier --checkOne \"{src,test}/**/*.{ts,tsx,js}\"",
        "format-force": "prettier --write \"{src,test}/**/*.{ts,tsx,js}\"",
        "lint": "eslint src/**/*.ts",
        "lint-fix": "eslint src/**/*.ts --fix",
        "publish-npm": "npm run build-all && npm publish --registry https://registry.npmjs.org",
        "publish-verdaccio": "npm run build-all && npm publish --registry http://localhost:4873",
        "test": "vitest run",
        "test-coverage": "vitest run --coverage",
        "test-watch": "vitest"
    },
    "files": [
        "dist/*"
    ],
    "license": "ISC",
    "devDependencies": {
        "@eslint/js": "^9.0.0",
        "@leyyo/leyyo-cli": "^1.0.18",
        "@types/express": "^5.0.6",
        "@types/mime-types": "^3.0.1",
        "@types/node": "^24.2.1",
        "@vitest/coverage-istanbul": "^4.0.18",
        "eslint": "^9.0.0",
        "eslint-config-prettier": "^10.1.8",
        "eslint-plugin-n": "^17.24.0",
        "eslint-plugin-unused-imports": "^4.4.1",
        "prettier": "^3.8.1",
        "ts-node": "^10.9.2",
        "typescript": "^5.9.3",
        "typescript-eslint": "^8.0.0",
        "vitest": "^4.0.18"
    },
    "dependencies": {
        "@leyyo/common": "4.0.5",
        "mime-types": "^3.0.2"
    }
}
